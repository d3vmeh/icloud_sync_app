{
  "folders": [
    {
      "id": "documents",
      "name": "Documents",
      "remote": "your-remote-name",
      "remote_path": "RemotePath/Folder",
      "local_path": "~/local-folder",
      "mode": "bisync",
      "sync_on_startup": false,
      "interval_minutes": null,
      "check_access": false,
      "keep_parent": true,
      "excludes": ["node_modules/**", ".git/**"]
    }
  ]
}
